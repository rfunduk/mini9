#!/usr/bin/env bash
# Run Odin unit tests for standalone lib packages.
# Usage: bin/test [package]   (default: all)
set -e

SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )/.." >/dev/null 2>&1 && pwd )"
cd "$SCRIPT_DIR"

PACKAGES=("lib/rove/tests")

if [ $# -gt 0 ]; then
  PACKAGES=("$@")
fi

FAILED=0
for pkg in "${PACKAGES[@]}"; do
  if [ ! -d "$pkg" ]; then
    echo "skip: $pkg (not a directory)"
    continue
  fi
  echo "==> $pkg"
  if ! odin test "$pkg" \
      -collection:lib="$SCRIPT_DIR/lib" \
      -define:LIBTESS2_LIB=../../../vendor/libtess2/build/libtess2.a; then
    FAILED=1
  fi
done

exit $FAILED
