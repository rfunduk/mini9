#!/usr/bin/env ruby

require "optparse"
require "pathname"
require "digest"
require "fileutils"

SRC_DIR = File.absolute_path("./source")

TARGET = ARGV[0] || "debug"
unless %w[debug release].include?(TARGET)
  puts "Invalid target. Choose 'debug' or 'release'."
  exit 1
end

def ruby_api_files
  return $ruby_api_files if $ruby_api_files

  ruby_api_dir = File.join(SRC_DIR, "../ruby_api")
  ruby_files = Dir.glob(File.join(ruby_api_dir, "*.rb"))
  $ruby_api_files = []

  ruby_files.each do |ruby_file|
    api_name = Pathname.new(ruby_file).basename(".rb").to_s

    auto = "load"
    has_cleanup = false
    odin_file = File.join(SRC_DIR, "engine_#{api_name}.odin")
    if File.exist?(odin_file)
      odin_content = File.read(odin_file)
      auto = "init" if odin_content.include?("setup_#{api_name} ::")
      has_cleanup = odin_content.include?("cleanup_#{api_name} ::")
    end

    # Collect all ENGINE declarations from leading comments
    type_mappings = []
    File.foreach(ruby_file) do |line|
      break unless line.start_with?("#") || line.strip.empty?
      if line =~ /^# ENGINE native=([.a-zA-Z0-9_]+) ruby=([.a-zA-Z0-9_]+)/
        type_mappings << [$1, $2]
      end
    end

    $ruby_api_files << [api_name, auto, type_mappings, has_cleanup]
  end

  $ruby_api_files = $ruby_api_files.sort_by(&:first)
end

def engine_methods
  return $engine_methods if $engine_methods

  puts "  Scanning for @engine_method functions..."
  $engine_methods = []

  Dir.glob(File.join(SRC_DIR, "*.odin")).each do |odin_file|
    lines = File.read(odin_file).split("\n")
    lines.each_with_index do |line, i|
      next unless line.include?("@engine_method:")

      name_match = line.match(/name="([^"]+)"/)
      # aspec is an mruby ARGS_* expression: ARGS_NONE, ARGS_ANY,
      # ARGS_REQ(2), ARGS_OPT(1), ARGS_ARG(2,1), or combinations like
      # ARGS_REQ(1)|ARGS_OPT(2). Match identifiers + optional (...) groups
      # joined by | (no spaces).
      aspec_match = line.match(/aspec=([A-Z_][A-Z_0-9]*(?:\([^)]*\))?(?:\|[A-Z_][A-Z_0-9]*(?:\([^)]*\))?)*)/)

      if name_match && aspec_match && i + 1 < lines.length
        method_name = name_match[1]
        aspec = aspec_match[1]
        next_line = lines[i + 1]

        if next_line =~ /(\w+)\s*::\s*proc\s*"c"/
          func_name = $1
          $engine_methods << [method_name, func_name, aspec]
        end
      end
    end
  end

  $engine_methods
end

def maybe_build_tools
  # we need to build macros here as rb2bin uses them
  # _build.sh still compiles it also :shrug:
  macros_c = "lib/mruby/macros.c"
  macros_o = "build/tools/macros.o"
  prev_digest_path = "bin/__macros_c__generated.digest"
  prev_digest = File.exist?(prev_digest_path) ? File.read(prev_digest_path) : nil
  current_digest = Digest::SHA256.file(macros_c).hexdigest

  if current_digest != prev_digest
    FileUtils.mkdir_p(File.dirname(macros_o))
    ok = system(
      "cc", "-c",
      "-I", "vendor/mruby/include",
      "-I", "vendor/mruby/build/host/include",
      macros_c,
      "-o", macros_o
    )
    raise "Unable to compile lib/mruby/macros.c" unless ok
    File.write(prev_digest_path, current_digest)
  end

  Dir.glob("bin/*.odin").map { Pathname.new(_1) }.each do |tool|
    name = tool.basename(".odin").to_s
    prev_digest_path = "bin/__#{name}__generated.digest"
    prev_digest = File.exist?(prev_digest_path) ? File.read(prev_digest_path) : nil
    current_digest = Digest::SHA256.file(tool.to_s).hexdigest

    next if prev_digest == current_digest

    print "Re-building tool #{name}"

    require "open3"
    cmd = [
      "odin", "build", tool.to_s, "-file",
      "-out:bin/__#{name}__generated",
      "-collection:lib=lib",
      "-define:MRUBY_LIB=../../vendor/mruby/build/host/lib/libmruby.a",
      "-define:MRUBY_MACROS_LIB=../../#{macros_o}",
      "-strict-style", "-vet"
    ]
    stdout, stderr, status = Open3.capture3(*cmd)
    unless status.success?
      puts
      warn stdout unless stdout.empty?
      warn stderr unless stderr.empty?
      raise "Unable to build tool #{name}"
    end
    File.write(prev_digest_path, current_digest)
    puts "\tOK\n"
  end
end

def generate
  File.write(
    File.join(SRC_DIR, "../ruby_api/auto__generated.rb"),
    "ENGINE_METHODS = [\n#{engine_methods.map { "\t\"#{_1[0]}\"" }.join(",\n")}\n]\n"
  )

  ruby_api_files.each do |api_name, _, _|
    puts "  Generating bytecode for #{api_name}..."

    convert_cmd = [
      "bin/__rb2bin__generated",
      "ruby_api/#{api_name}.rb",
      "ruby_api/#{api_name.gsub(/^_+|_+$/, "")}__generated.bin"
    ]
    convert_cmd << "--debug" if TARGET == "debug"

    result = system(*convert_cmd, out: File::NULL, err: File::NULL)
    raise "Unable to generate bytecode" unless result
  end

  init_content = []
  init_content << "package engine"
  init_content << "import rl \"lib:raylib\""
  init_content << "import mrb \"lib:mruby\""
  init_content << ""

  ruby_api_files.each do |api_name, _, _|
    name = api_name.gsub(/^_+|_+$/, "")
    init_content << "#{name}_bytecode := #load(\"../ruby_api/#{name}__generated.bin\")"
  end
  init_content << ""

  ruby_api_files.each do |api_name, type, type_mappings|
    next unless type == "init"
    type_mappings.each do |(native, ruby)|
      init_content << "#{ruby}_Ruby := mrb.Data_Type { struct_name = \"#{ruby}\", dfree = ruby_#{ruby.downcase}_finalizer }"
    end
  end

  init_content << ""
  init_content << "engine_init_ruby_api :: proc() {"
  init_content << "\tNATIVE_TO_MRUBY_TYPE = make(map[typeid]^mrb.Data_Type)"

  ruby_api_files.each do |_, type, type_mappings|
    next unless type == "init"
    type_mappings.each do |(native, ruby)|
      init_content << "\tNATIVE_TO_MRUBY_TYPE[#{native}] = &#{ruby}_Ruby"
    end
  end

  init_content << ""
  init_content << "\tkernel_module := mrb.module_get(g.mrb_state, \"Kernel\")"

  engine_methods.each do |name, f, aspec|
    # aspec is the literal text from the @engine_method annotation,
    # an mruby ARGS_* expression. Render with `mrb.` prefix.
    rendered = aspec.split("|").map { |s| "mrb.#{s}" }.join("|")
    init_content << "\tmrb.define_method(g.mrb_state, kernel_module, \"#{name}\", cast(rawptr)#{f}, #{rendered})"
  end

  # For init-type files: pre-register the data class (sets TT_DATA) BEFORE
  # loading bytecode. Otherwise class-body instances like `Vector2::ZERO = v2(0)`
  # get TT_OBJECT storage and data_init writes into wrong offsets.
  ruby_api_files.each do |api_name, type, type_mappings|
    init_content << "\n\t// #{api_name}"
    if type == "init"
      type_mappings.each do |(_, ruby)|
        init_content << "\tmrb.define_data_class(g.mrb_state, \"#{ruby}\")"
      end
    end
    init_content << "\tload_engine_bytecode(\"#{api_name}\", #{api_name.gsub(/^_+|_+$/, "")}_bytecode[:])"
    init_content << "\tsetup_#{api_name}()" if type == "init"
  end

  init_content << "}"

  init_content << ""
  init_content << "engine_cleanup_ruby_api :: proc() {"
  ruby_api_files.each do |api_name, _, _, has_cleanup|
    init_content << "\tcleanup_#{api_name}()" if has_cleanup
  end
  init_content << "}"

  puts "  Generating engine_ruby_api__generated.odin..."
  File.write(File.join(SRC_DIR, "engine_ruby_api__generated.odin"), init_content.join("\n") + "\n")
end

maybe_build_tools

puts "Linting source..."
unless system("bin/__lint__generated", "source")
  puts "Lint failed."
  exit 1
end

puts "Preparing '#{TARGET}'..."
FileUtils.rm_rf(File.absolute_path("./build/#{TARGET}"))

generate

puts "Building '#{TARGET}'..."
result = system({ "TARGET" => TARGET }, "bin/_build.sh")

unless result
  puts "Build failed with exit code #{$?.exitstatus}"
  exit $?.exitstatus
end

puts "Build complete."
