#!/usr/bin/env bash

set -e

DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )/.." >/dev/null 2>&1 && pwd )"

EXAMPLE=$1

EXAMPLE=${EXAMPLE#$DIR/}

if [[ -z "$EXAMPLE" ]] || [[ ! "$EXAMPLE" =~ ^games/ ]]; then
    EXAMPLE="games/test_game"
fi

echo "Building+opening $EXAMPLE..."

build/debug/mini9 package --web --source $EXAMPLE --output build/carts/
cd build/carts/$(basename $EXAMPLE)

# trap SIGINT and kill background server
cleanup() {
    if [[ -n "$SERVER_PID" ]]; then
        kill $SERVER_PID 2>/dev/null || true
    fi
    exit 0
}
trap cleanup SIGINT SIGTERM

# python -m http.server 8888 -d . &
# simple, eh? but it's nice to not have to worry about caching, so...

python -c "
from http.server import SimpleHTTPRequestHandler
from socketserver import TCPServer
from signal import SIGINT, signal
from socket import SOL_SOCKET, SO_REUSEADDR

class ZipZap(SimpleHTTPRequestHandler):
    def end_headers(self):
        self.send_header('Cross-Origin-Opener-Policy', 'same-origin')
        self.send_header('Cross-Origin-Embedder-Policy', 'require-corp')
        self.send_header('Access-Control-Allow-Origin', '*')
        self.send_header('Access-Control-Allow-Methods', 'GET,OPTIONS')
        self.send_header('Cache-Control', 'no-store, no-cache, must-revalidate')
        super().end_headers()

class ReusableTCPServer(TCPServer):
    def server_bind(self):
        self.socket.setsockopt(SOL_SOCKET, SO_REUSEADDR, 1)
        super().server_bind()

with ReusableTCPServer(('', 8888), ZipZap) as httpd:
    def signal_handler(signum, frame):
        print('\nShutting down...')
        httpd.shutdown()
        exit(0)

    signal(SIGINT, signal_handler)

    print('Serving at http://localhost:8888')
    httpd.serve_forever()
" &

SERVER_PID=$!
sleep 1
open http://localhost:8888

echo "Server running with PID $SERVER_PID at http://localhost:8888 (Press Ctrl+C to stop)"
wait $SERVER_PID
