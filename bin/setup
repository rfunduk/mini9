#!/usr/bin/env bash

MRUBY_VERSION="fafb52d72a2c09b6979c32ea5b97ce6f1af6a53d" # ideally 3.4.0 but it prevents loading any bytecode
EMSDK_VERSION="4.0.13"
BOX2D_VERSION="v3.1.1"
LIBTESS2_VERSION="8dbd6483e920311a58c9af10a10beb278efebc36"

ENGINE_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )/.." >/dev/null 2>&1 && pwd )"

echo -e "\n\n\n*** Installing development deps..."

# emscripten
echo -e "\n\nEmscripten"
echo "=========="
if [ -d "$ENGINE_DIR/vendor/emsdk" ]; then
    echo "emscripten already exists, updating..."
    (cd $ENGINE_DIR/vendor/emsdk && git fetch --tags && git checkout $EMSDK_VERSION)
else
    echo "Cloning emscripten..."
    git clone --branch $EMSDK_VERSION https://github.com/emscripten-core/emsdk.git $ENGINE_DIR/vendor/emsdk
fi
export EMSDK_QUIET=1
echo "Installing and activating emscripten..."
cd $ENGINE_DIR/vendor/emsdk
./emsdk install latest
./emsdk activate latest
source $ENGINE_DIR/vendor/emsdk/emsdk_env.sh

# mruby
echo -e "\n\nmruby"
echo "====="
if [ -d "$ENGINE_DIR/vendor/mruby" ]; then
    echo "mruby already exists, updating..."
    (cd $ENGINE_DIR/vendor/mruby && git fetch --tags && git checkout $MRUBY_VERSION)
else
    echo "Cloning mruby..."
    git clone https://github.com/mruby/mruby.git $ENGINE_DIR/vendor/mruby
    (cd $ENGINE_DIR/vendor/mruby && git checkout $MRUBY_VERSION)
fi
echo "Building mruby..."
cd $ENGINE_DIR/vendor/mruby
export MRUBY_CONFIG="$ENGINE_DIR/mruby.rb"
rake

# box2d
echo -e "\n\nbox2d"
echo "====="
if [ -d "$ENGINE_DIR/vendor/box2d" ]; then
    echo "box2d already exists, updating..."
    (cd $ENGINE_DIR/vendor/box2d && git fetch --tags && git checkout $BOX2D_VERSION)
else
    echo "Cloning box2d..."
    git clone --branch $BOX2D_VERSION https://github.com/erincatto/box2d.git $ENGINE_DIR/vendor/box2d
fi

echo "Building box2d (native)..."
cd $ENGINE_DIR/vendor/box2d
cmake -S . -B build -DBOX2D_SAMPLES=OFF -DBOX2D_BENCHMARKS=OFF -DBOX2D_DOCS=OFF -DBOX2D_UNIT_TESTS=OFF -DCMAKE_BUILD_TYPE=Release > /dev/null
cmake --build build --config Release > /dev/null

echo "Building box2d (emscripten/wasm)..."
source $ENGINE_DIR/vendor/emsdk/emsdk_env.sh
mkdir -p $ENGINE_DIR/vendor/box2d/build-wasm
cd $ENGINE_DIR/vendor/box2d/build-wasm
emcmake cmake -S .. -B . -DBOX2D_SAMPLES=OFF -DBOX2D_BENCHMARKS=OFF -DBOX2D_DOCS=OFF -DBOX2D_UNIT_TESTS=OFF -DCMAKE_BUILD_TYPE=Release > /dev/null
emmake make > /dev/null

# libtess2 — polygon tesselator (holes, self-intersections, shared edges)
echo -e "\n\nlibtess2"
echo "========"
if [ -d "$ENGINE_DIR/vendor/libtess2" ]; then
    echo "libtess2 already exists, updating..."
    (cd $ENGINE_DIR/vendor/libtess2 && git fetch && git checkout $LIBTESS2_VERSION && git pull)
else
    echo "Cloning libtess2..."
    git clone https://github.com/memononen/libtess2.git $ENGINE_DIR/vendor/libtess2
    (cd $ENGINE_DIR/vendor/libtess2 && git checkout $LIBTESS2_VERSION)
fi

echo "Building libtess2 (native)..."
cd $ENGINE_DIR/vendor/libtess2
rm -rf build && mkdir -p build
for f in Source/*.c; do
    cc -c -O2 -IInclude -o build/$(basename $f .c).o $f
done
ar rcs build/libtess2.a build/*.o

echo "Building libtess2 (emscripten/wasm)..."
source $ENGINE_DIR/vendor/emsdk/emsdk_env.sh
rm -rf build-wasm && mkdir -p build-wasm
for f in Source/*.c; do
    emcc -c -O2 -IInclude -o build-wasm/$(basename $f .c).o $f
done
emar rcs build-wasm/libtess2.a build-wasm/*.o
